# ─────────────────────────────────────────────                                                                                                                          
  # Strix Security Scanner — Environment Config                                                                                                                            
  # ─────────────────────────────────────────────                                                                                                                          
  # Copy to .env and fill in your values:                                                                                                                                  
  #   cp .env.example .env
                                                                                                                                                                           
  # ── Gemini LLM (required) ──────────────────
  # Get your key at: https://aistudio.google.com/apikey
  GEMINI_API_KEY=your-gemini-api-key-here                                                                                                                                  
   
  # ── Alternative LLM providers (use one) ────                                                                                                                            
  # OPENAI_API_KEY=
  # ANTHROPIC_API_KEY=                                                                                                                                                     
                  
  # Strix model string (uses LiteLLM's gemini/ prefix)                                                                                                                     
  # Options: gemini/gemini-2.5-pro, gemini/gemini-2.5-flash
  STRIX_LLM=gemini/gemini-2.5-pro                                                                                                                                          
                  
  # Separate model for report summarization (optional, defaults to STRIX_LLM)                                                                                              
  # SUMMARIZER_LLM=gemini/gemini-2.5-flash
                                                                                                                                                                           
  # ── S3 Storage (required) ──────────────────
  AWS_ACCESS_KEY_ID=                                                                                                                                                       
  AWS_SECRET_ACCESS_KEY=
  AWS_REGION=us-east-1                                                                                                                                                     
  S3_BUCKET=
  # Prefix where reports and scanned_repos.json are written                                                                                                                
  S3_REPORTS_PREFIX=shakedown-reports/                                                                                                                                     
   
  # ── GitHub PAT (required for private repos) ─                                                                                                                           
  # Needs repo scope for cloning private target repos
  REPO_CLONE_PAT=                                                                                                                                                          
   
  # ── Slack Notification (optional) ──────────                                                                                                                            
  SLACK_WEBHOOK_URL=
                                                                                                                                                                           
  # ── Jira Integration (optional) ────────────
  JIRA_BASE_URL=
  JIRA_EMAIL=
  JIRA_API_TOKEN=
  JIRA_PROJECT_KEY=SEC
                                                                                                                                                                           
  # ── Docker Socket (required on macOS) ──────
  # Strix uses Python's docker library which doesn't auto-detect                                                                                                           
  # macOS Docker Desktop's socket path. Uncomment for your setup:
  # DOCKER_HOST=unix://${HOME}/.docker/run/docker.sock
  # Colima:   DOCKER_HOST=unix://${HOME}/.colima/default/docker.sock                                                                                                       
  # Rancher:  DOCKER_HOST=unix://${HOME}/.rd/docker.sock
                                                                                                                                                                           
  # ── Advanced Strix Options (optional) ──────                                                                                                                            
  # STRIX_REASONING_EFFORT=high